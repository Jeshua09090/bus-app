# Copy to .env for local development.
# Do not commit real tokens, project refs, database URLs, or local dumps.

# Public client configuration. These values are bundled into Expo builds.
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_GOOGLE_PLACES_KEY=

# Native Mapbox download token used by @rnmapbox/maps during native builds.
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=

# Optional EAS metadata. Leave blank for local-only development.
EAS_PROJECT_ID=

# Maintainer-only fallback project refs for partial planner data.
# Most contributors should leave this empty.
EXPO_PUBLIC_PARTIAL_PLANNER_PROJECT_REFS=

# Snapshot generator local database path. Prefer this for local RAPTOR data work.
SNAPSHOT_DATABASE_URL=
